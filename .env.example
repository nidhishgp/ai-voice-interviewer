# =============================================================================
# VoiceScreen — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit
# Local dev: use the Docker command in docs/local-dev.md
# Prod:      LiveKit Cloud → https://cloud.livekit.io
# -----------------------------------------------------------------------------
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# -----------------------------------------------------------------------------
# LLM Provider
# Local:  ollama (run `ollama pull llama3.2` first)
# Prod:   openai or anthropic
# Values: ollama | openai | anthropic
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Evaluator uses a more capable model than the real-time agent
# Local: same as LLM_MODEL (swap to gpt-4o in prod)
EVALUATOR_LLM_MODEL=llama3.2

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# STT — Deepgram (same provider local + prod)
# Free tier: $200 credits, no card required → https://deepgram.com
# -----------------------------------------------------------------------------
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# -----------------------------------------------------------------------------
# TTS
# Local: kokoro-local (runs on CPU, no API key needed)
# Prod:  cartesia (better voice quality) → https://cartesia.ai
# Values: kokoro-local | cartesia
# -----------------------------------------------------------------------------
TTS_PROVIDER=kokoro-local

# Required when TTS_PROVIDER=cartesia
CARTESIA_API_KEY=

# -----------------------------------------------------------------------------
# Supabase
# Local:  run `supabase start` (Supabase CLI required)
# Prod:   https://supabase.com → create a project
# -----------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Next.js public env (browser-accessible — anon key only, never service role)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Internal API secret — agent worker → Fastify API
# Must be a strong random string (min 32 chars) in production
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
INTERNAL_SECRET=dev-secret-change-in-prod

# -----------------------------------------------------------------------------
# Sentry — error tracking (leave empty to disable locally)
# https://sentry.io → create a project → get DSN
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
